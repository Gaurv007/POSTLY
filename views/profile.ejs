<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #2193b0, #6dd5ed);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .profile-card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            width: 350px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: #ddd;
            margin: 0 auto 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 40px;
            color: #555;
        }

        h2 {
            margin: 10px 0;
            color: #333;
        }

        p {
            color: #666;
            margin: 5px 0;
        }

        .btn {
            display: block;
            margin: 10px 0;
            padding: 10px;
            border: none;
            border-radius: 6px;
            text-decoration: none;
            color: white;
            font-weight: bold;
            transition: 0.3s;
        }

        .edit {
            background: #2193b0;
        }

        .edit:hover {
            background: #1b7f96;
        }

        .logout {
            background: #e74c3c;
        }

        .logout:hover {
            background: #c0392b;
        }
    </style>
</head>
<body>

    <div class="profile-card">
        <div class="avatar">👤</div>

        <h2>John Doe</h2>
        <p>@johndoe</p>
        <p>johndoe@email.com</p>
        <p>+91 9876543210</p>

        <a href="/edit-profile" class="btn edit">Edit Profile</a>
        <a href="/logout" class="btn logout">Logout</a>
    </div>

</body>
</html>